#!/usr/bin/env python3
"""
🥊 OS CONFRONTOS DO M2  —  MEIRELES/BARBOSA  vs  ADVERSÁRIOS      (14 jul 2026)

    python3 confrontos_m2.py barbosa

O VASCO, 14 jul:
    "quando um jogador está em transição — considera a EQUIPA em transição."
    "mostra-me todas as situações possíveis: Defesa vs Ataque · Transição vs Ataque ·
     Ataque vs Ataque · Ataque vs Transição · Ataque vs Defesa..."
    "IMPORTANTE: detetar as EQUIPAS nos diferentes pontos. Tens de te cingir às MESMAS
     equipas."   ← e é por isto que o par é ORDENADO: A×B ≠ B×A.
    "o Meireles e o Barbosa são a equipa que tem o jogador de VERMELHO."

------------------------------------------------------------------------------------
🧱 A F2, com a cláusula dele:

        DEFESA     =  os DOIS atrás da costura de TRÁS da parede
        ATAQUE     =  os DOIS à frente da costura da FRENTE
        TRANSIÇÃO  =  TUDO O RESTO  ← basta UM em transição. E a equipa PARTIDA
                                      (um no fundo, outro na rede) também é TRANSIÇÃO.
        (⚠️ as marcas são as COSTURAS DA PAREDE, NÃO a linha de serviço)

👥 J9–J13 — A IDENTIDADE DAS EQUIPAS. O lado do ECRÃ **NÃO** é a equipa: elas TROCAM.

        pt  1 →  6    MEIRELES em BAIXO
        pt  7 → 20    MEIRELES em CIMA      ← mudança de campo
        pt 21         MEIRELES em BAIXO     ← mudança de campo (set novo)

        📐 MEDIDO A OLHAR, nos 21 serviços (QUEM_E_QUEM_barbosa.png), com DUAS âncoras
           independentes que concordam sem se conhecerem (D14/D16):
              ① a camisola VERMELHA (Meireles)   ② o BONÉ branco (o adversário)
        ⛔ A COR MÉDIA DO TRONCO NÃO SERVE — o azul do campo domina o recorte (D13).
           É o mesmo erro que matou a tentativa de separar a bola do ténis pela cor.

------------------------------------------------------------------------------------
⚠️ OS AJUSTES QUE ISTO LEVA — declarados AQUI, à cabeça (regra 2):

  🔢 IOU_MESMA_PESSOA = 0,55   ⚠️ AJUSTE MEU, NÃO É LEI DELE.
     "duas boxes praticamente em cima uma da outra são a MESMA PESSOA."
     É a B1 dele — "a bola nunca pousa duas vezes no mesmo sítio" — nos JOGADORES.
     Sem isto o J4 fica com o MESMO jogador a dobrar e deita fora o parceiro VERDADEIRO:
     acontecia em 16,5% dos frames. 🚨 E dava a fase CERTA, com CONFIANÇA, pelo motivo
     ERRADO.

  🔢 MIN_SEG = 0,4 s          ⚠️ AJUSTE MEU. Anti-jitter (F5).
     🔴 E FUNDE, NÃO APAGA. Um segmento curto demais é TREMOR da box ⇒ vai para o
        estado ANTERIOR (D1: em dúvida, mantém o estado anterior).
        ⛔ A versão anterior DEITAVA FORA esses frames: 7,7% do tempo dos pontos
           EVAPORAVA-SE. Viola a D7 (nunca omitir) e a diretriz de produto.
     👉 A tolerância vive no TEMPO, nunca no ESPAÇO (D19).

⚠️ FICHEIRO NOVO. Não toca no gerar_tempo_util.py. Não corre modelo nenhum.
"""
import sys, pickle, itertools
from pathlib import Path
import cv2, numpy as np

VID = sys.argv[1] if len(sys.argv) > 1 else "barbosa"
sys.argv = [sys.argv[0], VID]
import cascata_jogadores as C
from fases_m2 import fase_do_jogador, LINHAS

RAIZ = Path(__file__).parent

IOU_MESMA_PESSOA = 0.55
MIN_SEG = 0.4
HISTERESE_S = 0.0
#    "uma fase não acaba porque saiu. Só acaba se ficar 2 s FORA. Se voltar antes, não acabou."
#    É a D1 (histerese) e a D19 (a tolerância vive no TEMPO) aplicadas à FASE DA EQUIPA.
#    ⚠️ ÂMBITO: à EQUIPA (a decisão dele). Um CEGO (None) NÃO segura o estado (D2/D4).

PONTOS = {"barbosa": [(13.6, 23.7), (33.9, 37.3), (40.3, 44.7), (54.5, 62.4),
                      (69.8, 73.6), (83.3, 96.0), (135.0, 139.1), (155.0, 157.6),
                      (162.9, 171.8), (188.3, 192.2), (196.0, 202.0), (227.2, 230.8),
                      (242.3, 245.4), (257.1, 266.0), (298.3, 306.8), (326.1, 337.3),
                      (352.1, 357.3), (367.9, 371.1), (377.9, 384.3), (406.8, 416.1),
                      (526.0, 533.9)]}
MP4 = {"barbosa": RAIZ / "../BarbosaMeireles.mp4", "parada4": RAIZ / "../Parada4.mp4"}

# 👥 J9-J13 — de que LADO está a equipa A (MEIRELES/BARBOSA, o de VERMELHO), por ponto.
#    MEDIDO A OLHAR nos 21 serviços. ⚠️ O lado do ECRÃ NÃO é a equipa.
A = "MEIRELES"
B = "ADVERSARIOS"
LADO_A = {p: ("baixo" if (p <= 6 or p == 21) else "cima") for p in range(1, 22)}

FASES = ("DEFESA", "TRANSICAO", "ATAQUE")
COR = {"DEFESA": (80, 200, 90), "TRANSICAO": (40, 190, 250), "ATAQUE": (70, 90, 240),
       None: (150, 150, 150)}
F = cv2.FONT_HERSHEY_SIMPLEX


def iou(a, b):
    xa, ya, xb, yb = max(a[0], b[0]), max(a[1], b[1]), min(a[2], b[2]), min(a[3], b[3])
    i = max(0, xb - xa) * max(0, yb - ya)
    u = (a[2]-a[0])*(a[3]-a[1]) + (b[2]-b[0])*(b[3]-b[1]) - i
    return i / u if u else 0


def mesma_pessoa(pb):
    """⚠️ AJUSTE MEU — a B1 dele, nos JOGADORES. Corre ANTES do J4."""
    out, n = [], 0
    for fr in pb:
        keep = []
        for b in sorted(fr, key=lambda b: -(b[2]-b[0])*(b[3]-b[1])):
            if any(iou(b, k) >= IOU_MESMA_PESSOA for k in keep):
                n += 1
            else:
                keep.append(b)
        out.append(keep)
    return out, n


def fase_da_equipa(fr, l):
    """👥 F1 · 🧱 F2 (com a cláusula dele) · 🚫 D2/D4 — se não vejo os DOIS, NÃO INVENTO."""
    eq = [b for b in fr if C.lado(b) == l]
    if len(eq) != 2:
        return None
    f = [fase_do_jogador(b) for b in eq]
    if all(x == "DEFESA" for x in f):
        return "DEFESA"
    if all(x == "ATAQUE" for x in f):
        return "ATAQUE"
    return "TRANSICAO"                       # ← basta um em transição, ou a equipa partida


def histerese(serie1, fps):
    """🔴 REGRA DO VASCO — a fase da EQUIPA só muda se a nova se AGUENTAR HISTERESE_S.
       Se sair e VOLTAR antes disso, a fase NÃO acabou (D1). É por EQUIPA (uma série).
       ⚠️ CEGO (None) não segura nem impõe estado: passa à frente sem mexer no confirmado."""
    n = int(round(HISTERESE_S * fps))
    out = list(serie1)
    estado = next((s for s in serie1 if s is not None), None)
    i = 0
    while i < len(serie1):
        s = serie1[i]
        if s is None or s == estado:
            out[i] = s if s is None else estado
            i += 1
            continue
        # candidato a mudança: só vale se PERSISTIR n frames seguidos (ignorando cegos)
        j, seguidos = i, 0
        while j < len(serie1) and seguidos < n:
            if serie1[j] == s:
                seguidos += 1
            elif serie1[j] is not None and serie1[j] != s:
                break                       # apareceu OUTRA coisa ⇒ não confirmou
            j += 1
        if seguidos >= n:                   # confirmou ⇒ muda a partir de i
            estado = s
            out[i] = s
            i += 1
        else:                               # não confirmou ⇒ mantém o estado (D1)
            out[i] = estado
            i += 1
    return out


def segmentos(serie, fps):
    """🔗 Colapsa em segmentos. 🔴 O jitter FUNDE-SE NO ANTERIOR — não se apaga (D1/D7).
       ⇒ NENHUM frame se perde. Só os CEGOS ficam de fora — e isso é a D2/D4, é honesto."""
    seg = []
    for k, s in enumerate(serie):
        if seg and seg[-1][0] == s:
            seg[-1][2] = k
        else:
            seg.append([s, k, k])
    mudou = True
    while mudou:                             # 🔁 funde os curtos, até estabilizar
        mudou = False
        for i, (s, a, b) in enumerate(seg):
            if (b - a + 1) / fps >= MIN_SEG or len(seg) == 1:
                continue
            j = i - 1 if i else 1            # o ANTERIOR (ou o seguinte, se for o 1.º)
            seg[j][1], seg[j][2] = min(seg[j][1], a), max(seg[j][2], b)
            seg.pop(i)
            mudou = True
            break
    out, fim = [], []                        # recose vizinhos iguais
    for s, a, b in seg:
        if fim and fim[-1][0] == s:
            fim[-1][2] = b
        else:
            fim.append([s, a, b])
    return [tuple(x) for x in fim]


def curva(img, coef, cor, esp=2):
    p = [(x, int(C.ev(C.cal[coef], x))) for x in range(0, img.shape[1], 6)]
    for i in range(len(p) - 1):
        cv2.line(img, p[i], p[i+1], cor, esp, cv2.LINE_AA)


def main():
    fps = C.FPS
    pts = PONTOS[VID]
    pb = C.j1_pes_no_poligono(pickle.load(open(C.BOXES, "rb"))["player_boxes"])
    pb, n_dup = mesma_pessoa(pb)
    pb = C.j4_dois_por_lado(C.j5_continuidade(pb)[0])

    print("=" * 92)
    print(f"🥊 OS CONFRONTOS DO M2 — {A} / BARBOSA (o de VERMELHO)  ×  {B} (o do BONÉ)")
    print("=" * 92)
    print("   🧱 F2 (Vasco): basta UM em transição ⇒ a EQUIPA está em TRANSIÇÃO.")
    print("   👥 J9-J13: as equipas TROCAM DE LADO. pt 1-6 e 21: MEIRELES em BAIXO. "
          "pt 7-20: em CIMA.")
    print(f"   ⚠️ ajuste meu: {n_dup} boxes eram a MESMA pessoa (IoU≥{IOU_MESMA_PESSOA}) "
          f"⇒ apagadas ANTES do J4.")
    print(f"   ⚠️ ajuste meu: jitter < {MIN_SEG}s FUNDE-SE no anterior (D1). "
          f"NÃO se apaga — nenhum frame se perde.\n")

    # 🧪 O TESTE GRÁTIS (regra dos cortes do Vasco): mudanças LEGAIS = só com a transição
    #    pelo meio. DEFESA↔ATAQUE sem passar por TRANSIÇÃO é IMPOSSÍVEL ⇒ conta-se como BUG.
    def ilegais(seq_fases):
        n = 0
        f = [s for s, _, _ in seq_fases if s is not None]
        for x, y in zip(f, f[1:]):
            if {x, y} == {"DEFESA", "ATAQUE"}:
                n += 1
        return n

    pilhas, T, saltos = {}, dict(dur=0, cont=0, cego=0), 0
    print("   pt      t     dur    a sequência do ponto   (MEIRELES × ADVERSARIOS)")
    print("   " + "-" * 86)
    for i, (t0, t1) in enumerate(pts, 1):
        f0, f1 = int(t0 * fps), int(t1 * fps)
        la = LADO_A[i]
        lb = "cima" if la == "baixo" else "baixo"
        sa = histerese([fase_da_equipa(pb[f], la) for f in range(f0, f1+1) if f < len(pb)], fps)
        sb = histerese([fase_da_equipa(pb[f], lb) for f in range(f0, f1+1) if f < len(pb)], fps)
        serie = list(zip(sa, sb))
        seq = segmentos(serie, fps)
        saltos += ilegais([(s[0], a, b) for s, a, b in seq]) + \
                  ilegais([(s[1], a, b) for s, a, b in seq])

        linha = []
        for s, a, b in seq:
            dur = (b - a + 1) / fps
            T["dur"] += dur
            if None in s:
                T["cego"] += dur
                linha.append(f"[cego {dur:.1f}s]")
                continue
            T["cont"] += dur
            pilhas.setdefault(s, []).append((i, f0 + a, f0 + b))
            linha.append(f"{s[0][:3]}×{s[1][:3]} {dur:.1f}s")
        print(f"   {i:2}  {t0:6.1f}s {t1-t0:5.1f}s   " + " → ".join(linha))

    print("\n   " + "-" * 86)
    print(f"   APONTADO: {T['cont']/T['dur']*100:.1f}%   ·   "
          f"CEGO (não vejo os 2 — D2/D4, não invento): {T['cego']/T['dur']*100:.1f}%   ·   "
          f"PERDIDO: 0,0%")
    print(f"\n   🧪 SALTOS ILEGAIS (DEFESA↔ATAQUE sem transição — IMPOSSÍVEL ⇒ bug): "
          f"{saltos}   (histerese={HISTERESE_S}s)")

    print("\n" + "=" * 92)
    print(f"🥊 AS 9 SITUAÇÕES   ({A} × {B})")
    print("=" * 92)
    cap = cv2.VideoCapture(str(MP4[VID]))
    W = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    Hh = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))

    for ca, cb in itertools.product(FASES, FASES):
        cl = pilhas.get((ca, cb), [])
        tot = sum((b - a + 1) / fps for _, a, b in cl)
        nome = f"M2_{ca}_x_{cb}"
        print(f"   {ca:9} × {cb:9}   {len(cl):2} clips   {tot:5.1f}s"
              + ("" if cl else "   ⚠️ VAZIO"))
        if not cl:
            continue
        out = cv2.VideoWriter(str(RAIZ / f"../{nome}_{VID}.mp4"),
                              cv2.VideoWriter_fourcc(*"mp4v"), fps, (W, Hh))
        for pt, a, b in cl:
            la = LADO_A[pt]
            cap.set(cv2.CAP_PROP_POS_FRAMES, a)
            for f in range(a, b + 1):
                ok, img = cap.read()
                if not ok:
                    break
                for l in ("cima", "baixo"):
                    fr_, tr_ = LINHAS[l]
                    curva(img, tr_, (90, 90, 90), 2)
                    curva(img, fr_, (200, 200, 200), 2)
                curva(img, "rede_base_coef", (200, 120, 40), 1)
                for bx in (pb[f] if f < len(pb) else []):
                    x, y = C.pes(bx)
                    fj = fase_do_jogador(bx)
                    eq = A if C.lado(bx) == la else B
                    cv2.rectangle(img, (int(bx[0]), int(bx[1])), (int(bx[2]), int(bx[3])),
                                  COR[fj], 2)
                    cv2.drawMarker(img, (int(x), int(y)), COR[fj], cv2.MARKER_CROSS, 13, 2)
                    cv2.putText(img, eq[:4], (int(bx[0]), int(bx[1]) - 5), F, .42,
                                (255, 255, 255), 1, cv2.LINE_AA)
                cv2.putText(img, f"{A}:    {ca}", (14, 28), F, .72, COR[ca], 2, cv2.LINE_AA)
                cv2.putText(img, f"{B}: {cb}", (14, 54), F, .72, COR[cb], 2, cv2.LINE_AA)
                cv2.putText(img, f"ponto {pt}   t={f/fps:6.1f}s   ({A} em {la.upper()})",
                            (W - 420, 28), F, .55, (255, 255, 255), 2, cv2.LINE_AA)
                out.write(img)
        out.release()
    cap.release()
    print(f"\n   🎬 os MP4 estão na raiz:  M2_<FASE_A>_x_<FASE_B>_{VID}.mp4")


if __name__ == "__main__":
    main()
